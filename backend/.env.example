# ══════════════════════════════════════════════════════
#  Kesara Bathik — Backend Environment Variables
#  Copy this to .env locally. On Railway, add each
#  variable directly in the Railway Dashboard → Variables.
# ══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ────────────────────────────────────
# Format: mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kesara-batik?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_make_it_long_random_at_least_32_chars
JWT_EXPIRE=30d

# ── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── PayPal ───────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=live

# ══════════════════════════════════════════════════════
#  BREVO EMAIL (Transactional Emails)
#  Your domain kesarabathik.com is already authenticated
#  in Brevo (DKIM ✅ DMARC ✅). Just fill these in.
# ══════════════════════════════════════════════════════

# From Brevo: Settings → SMTP & API → SMTP tab
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=b07266001@smtp-brevo.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_password_from_dashboard

# "From" address shown to recipients.
# MUST use your authenticated domain: @kesarabathik.com
# This does NOT need to be a real inbox — it's display only.
EMAIL_FROM=orders@kesarabathik.com
EMAIL_FROM_NAME=Kesara Bathik

# Where admin "new order" notifications are sent.
# Use a real inbox you actually check daily.
ADMIN_EMAIL=your_real_inbox@gmail.com

# ── Frontend URL (for CORS) ───────────────────────────
FRONTEND_URL=https://www.kesarabathik.com
