# ══════════════════════════════════════════════════════
#  Kesara Bathik — Backend Environment Variables
#  Add each variable in Railway → your service → Variables
# ══════════════════════════════════════════════════════

PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kesara-batik?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_make_it_long_random_at_least_32_chars
JWT_EXPIRE=30d

# ── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ══════════════════════════════════════════════════════
#  DIALOG GENIE PAYMENT GATEWAY
#  From: https://dashboard.geniebiz.lk → Connect → Applications
#  IMPORTANT: never commit real keys to GitHub.
# ══════════════════════════════════════════════════════
GENIE_MODE=production
GENIE_API_BASE=https://api.geniebiz.lk/public
GENIE_APP_ID=your_genie_application_id
GENIE_APP_KEY=your_genie_api_key_secret
# Backward-compatible alias if your Railway variable already uses this name:
# GENIE_API_SECRET=your_genie_api_key_secret

# Public URL of YOUR BACKEND on Railway (Genie calls this for webhooks)
BACKEND_URL=https://kesara-batik-production.up.railway.app

# Public URL of YOUR FRONTEND. Match the exact Genie application domain.
FRONTEND_URL=https://www.kesarabathik.com

# ══════════════════════════════════════════════════════
#  BREVO EMAIL
# ══════════════════════════════════════════════════════
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=b07266001@smtp-brevo.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_password
EMAIL_FROM=orders@kesarabathik.com
EMAIL_FROM_NAME=Kesara Bathik
ADMIN_EMAIL=your_real_inbox@gmail.com

