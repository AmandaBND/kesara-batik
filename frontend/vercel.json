{
  "headers": [
    {
      "source": "/privacy-policy",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow, noarchive" }]
    },
    {
      "source": "/return-refund-policy",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow, noarchive" }]
    },
    {
      "source": "/terms-and-conditions",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow, noarchive" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }]
    }
  ],
  "rewrites": [
    { "source": "/products", "destination": "/seo-products.html" },
    { "source": "/new-arrivals", "destination": "/seo-new-arrivals.html" },
    { "source": "/women", "destination": "/seo-women.html" },
    { "source": "/men", "destination": "/seo-men.html" },
    { "source": "/kids", "destination": "/seo-kids.html" },
    { "source": "/family-kits", "destination": "/seo-family-kits.html" },
    { "source": "/accessories", "destination": "/seo-accessories.html" },
    { "source": "/faq", "destination": "/seo-faq.html" },

    { "source": "/products/:slug", "destination": "/index.html" },
    { "source": "/cart", "destination": "/index.html" },
    { "source": "/checkout", "destination": "/index.html" },
    { "source": "/account", "destination": "/index.html" },
    { "source": "/orders", "destination": "/index.html" },
    { "source": "/orders/:path*", "destination": "/index.html" },
    { "source": "/wishlist", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/privacy-policy", "destination": "/index.html" },
    { "source": "/return-refund-policy", "destination": "/index.html" },
    { "source": "/terms-and-conditions", "destination": "/index.html" },
    { "source": "/payment/:path*", "destination": "/index.html" },
    { "source": "/order-success/:path*", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" }
  ]
}
