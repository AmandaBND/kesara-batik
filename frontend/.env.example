# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_URL=http://localhost:5000/api

# Google OAuth (Sign in with Google)
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# 2. Add Authorized JavaScript origins (exact match, no trailing slash):
#    - http://localhost:5173
#    - https://your-production-domain.com
# 3. Use the SAME Client ID in backend GOOGLE_CLIENT_ID and here
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Stripe (Public Key)
# Get this from Stripe Dashboard: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# PayPal (Client ID)
# Get this from PayPal Developer: https://developer.paypal.com/dashboard
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
