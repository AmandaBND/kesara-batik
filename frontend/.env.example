# ══════════════════════════════════════════════════════
#  Kesara Bathik — Frontend Environment Variables
#  On Vercel: Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════

# Backend API (your Railway backend URL + /api)
VITE_API_URL=https://kesara-batik-production.up.railway.app/api

# Google OAuth (Sign in with Google)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Dialog Genie Public Key — new IPG app for www.kesarabathik.com
VITE_GENIE_PUBLIC_KEY=pk_production_
